{{!
    @template local_chemillusion/teacher_demo_cta

    Teacher demo / adoption call to action.

    Context variables required for this template:
    * demo_url string
    * blurb string

    Example context (json):
    {
        "demo_url": "https://chemillusion.com/demo",
        "blurb": "See ChemIllusion teacher workflows."
    }
}}
<div class="local-chemillusion-cta alert alert-secondary" role="note">
    <p class="mb-2">{{blurb}}</p>
    <a class="btn btn-outline-primary" href="{{demo_url}}" target="_blank" rel="noopener noreferrer">
        {{#str}}cta_teacher_demo, local_chemillusion{{/str}}
    </a>
</div>
