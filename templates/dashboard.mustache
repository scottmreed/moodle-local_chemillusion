{{!
    @template local_chemillusion/dashboard

    ChemIllusion landing/dashboard.

    Context variables required for this template:
    * heading string
    * intro string
    * toolsurl string
    * cardsurl string
    * graphicalurl string
    * graphical_enabled bool
    * diagram_tools array
    * has_diagram_tools bool
    * privacyurl string
    * linking_enabled bool
    * linkurl string
    * isteacher bool
    * teacher_blurb string
    * demo_url string
    * metrics array of { label, value }
}}
<div class="local-chemillusion-dashboard">
    <p class="lead">{{{intro}}}</p>

    {{#has_diagram_tools}}
        <section class="local-chemillusion-diagram-tools mb-4" aria-labelledby="local-chemillusion-diagram-tools-heading">
            <div class="local-chemillusion-section-heading">
                <div>
                    <h2 id="local-chemillusion-diagram-tools-heading">
                        {{#str}}diagram_tools_heading, local_chemillusion{{/str}}
                    </h2>
                    <p class="text-muted mb-0">{{#str}}diagram_tools_intro, local_chemillusion{{/str}}</p>
                </div>
                <a class="btn btn-outline-secondary btn-sm" href="{{graphicalurl}}">
                    {{#str}}diagram_tools_saved, local_chemillusion{{/str}}
                </a>
            </div>
            <div class="local-chemillusion-diagram-tool-grid">
                {{#diagram_tools}}
                    <a class="local-chemillusion-diagram-tool" href="{{url}}">
                        <span class="local-chemillusion-diagram-tool-visual" role="img" aria-label="{{imagealt}}">
                            {{#is_molecule}}
                                <span class="local-chemillusion-smiles-sample">ClCCCCBr</span>
                            {{/is_molecule}}
                            {{#is_newman}}
                                <img src="{{imageurl}}" alt="">
                            {{/is_newman}}
                            {{#is_reaction}}
                                <img src="{{imageurl}}" alt="">
                            {{/is_reaction}}
                            {{#is_orbital}}
                                <span class="local-chemillusion-bond-comparison">
                                    <strong>&pi;</strong>
                                    <span>{{#str}}diagram_tool_versus, local_chemillusion{{/str}}</span>
                                    <b>&sigma;</b>
                                </span>
                            {{/is_orbital}}
                        </span>
                        <span class="local-chemillusion-diagram-tool-copy">
                            <strong>{{title}}</strong>
                            <small>{{description}}</small>
                        </span>
                        <span class="local-chemillusion-diagram-tool-arrow" aria-hidden="true">&rarr;</span>
                    </a>
                {{/diagram_tools}}
            </div>
        </section>
    {{/has_diagram_tools}}

    <nav class="local-chemillusion-nav mb-4" aria-label="ChemIllusion">
        <div class="list-group">
            <a class="list-group-item list-group-item-action" href="{{toolsurl}}">
                <strong>{{#str}}tools_heading, local_chemillusion{{/str}}</strong>
                <small class="d-block text-muted">Look up molecules by name, SMILES, or InChI</small>
            </a>
            <a class="list-group-item list-group-item-action" href="{{cardsurl}}">
                <strong>{{#str}}cards_heading, local_chemillusion{{/str}}</strong>
                <small class="d-block text-muted">Create and study flashcard decks</small>
            </a>
            {{#graphical_enabled}}
            <a class="list-group-item list-group-item-action" href="{{graphicalurl}}">
                <strong>{{#str}}graphical_cards_heading, local_chemillusion{{/str}}</strong>
                <small class="d-block text-muted">Newman projections, orbital diagrams, reaction coordinate cards</small>
            </a>
            {{/graphical_enabled}}
            {{#linking_enabled}}
                <a class="list-group-item list-group-item-action" href="{{linkurl}}">
                    <strong>{{#str}}link_start, local_chemillusion{{/str}}</strong>
                    <small class="d-block text-muted">Connect your ChemIllusion account</small>
                </a>
            {{/linking_enabled}}
            <a class="list-group-item list-group-item-action" href="{{privacyurl}}">
                <strong>{{#str}}privacy_page_heading, local_chemillusion{{/str}}</strong>
                <small class="d-block text-muted">View how your data is used</small>
            </a>
        </div>
    </nav>

    {{#isteacher}}
        <section class="local-chemillusion-teacher mt-4" aria-label="{{#str}}metric_lookups, local_chemillusion{{/str}}">
            <p>{{teacher_blurb}}</p>
            <dl class="row local-chemillusion-metrics">
                {{#metrics}}
                    <dt class="col-sm-3">{{label}}</dt>
                    <dd class="col-sm-3">{{value}}</dd>
                {{/metrics}}
            </dl>
            <a class="btn btn-outline-secondary" href="{{demo_url}}" target="_blank" rel="noopener noreferrer">
                {{#str}}cta_teacher_demo, local_chemillusion{{/str}}
            </a>
        </section>
    {{/isteacher}}
</div>
