{{!
    @template local_chemillusion/study_deck

    List of study decks.

    Context variables required for this template:
    * heading string
    * decks array of { id, name, cardcount, viewurl }
    * hasdecks bool
    * emptytext string
    * cancreate bool
    * courseid int

    Example context (json):
    {
        "heading": "Study decks",
        "decks": [
            {
                "id": 1,
                "name": "Alkanes",
                "cardcount": 4,
                "viewurl": "#"
            }
        ],
        "hasdecks": true,
        "emptytext": "No decks yet.",
        "cancreate": true,
        "courseid": 0
    }
}}
<div class="local-chemillusion-decks">
    {{#hasdecks}}
        <ul class="list-group">
            {{#decks}}
                <li class="list-group-item d-flex justify-content-between align-items-center">
                    <a href="{{viewurl}}">{{name}}</a>
                    <span class="badge badge-secondary badge-pill">{{cardcount}}</span>
                </li>
            {{/decks}}
        </ul>
    {{/hasdecks}}
    {{^hasdecks}}
        <p class="text-muted">{{emptytext}}</p>
    {{/hasdecks}}

    {{#cancreate}}
        <div class="mt-3" data-region="deck-create" data-courseid="{{courseid}}">
            <button type="button" class="btn btn-success" data-action="create-deck">
                {{#str}}deck_create, local_chemillusion{{/str}}
            </button>
        </div>
    {{/cancreate}}
</div>
