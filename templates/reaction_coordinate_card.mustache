{{!
    @template local_chemillusion/reaction_coordinate_card

    Reaction coordinate diagram card shell. JS replaces the SVG region
    with a live rendered diagram using reaction_coordinate_diagram.js.

    Context variables required for this template:
    * name string
    * frontjson string (JSON: { template, points, annotations, title, x_axis, y_axis, disclaimer, teacher_note })
    * summary string
    * summaryvisible bool
    * canexport bool
    * exportenabled bool
    * pngexportenabled bool
    * rcd_disclaimer string  Localised disclaimer text.

    Example context (json):
    {
        "name": "SN2 profile",
        "frontjson": "{\"template\":\"sn2\"}",
        "summary": "Two-step energy profile.",
        "summaryvisible": true,
        "canexport": true,
        "exportenabled": true,
        "pngexportenabled": false,
        "rcd_disclaimer": "Schematic only."
    }}
<div class="local-chemillusion-reaction-coordinate-editor"
     data-region="rcd-card"
     data-frontjson="{{frontjson}}">

    <div class="local-chemillusion-card-face"
         data-region="card-front"
         role="img"
         aria-label="{{summary}}">
        {{! reaction_coordinate_diagram.js renders SVG here }}
        <noscript>
            <p class="text-muted">{{#str}}rdkit_failed, local_chemillusion{{/str}}</p>
        </noscript>
    </div>

    <p class="local-chemillusion-rcd-disclaimer">
        {{#str}}rcd_qualitative_disclaimer, local_chemillusion{{/str}}
    </p>

    <div class="mt-2 text-center">
        <button class="btn btn-primary" type="button"
                data-action="flip-card" aria-expanded="false">
            {{#str}}card_show_answer, local_chemillusion{{/str}}
        </button>
    </div>

    <div class="local-chemillusion-card-face mt-2" data-region="card-back" hidden aria-live="polite">
    </div>

    <div class="local-chemillusion-accessible-summary mt-2"
         {{^summaryvisible}}hidden{{/summaryvisible}}>
        {{summary}}
    </div>

    {{#exportenabled}}
    {{#canexport}}
    <div class="local-chemillusion-svg-toolbar mt-3">
        <button class="btn btn-sm btn-outline-secondary" type="button" data-action="export-svg">
            {{#str}}export_svg, local_chemillusion{{/str}}
        </button>
        {{#pngexportenabled}}
        <button class="btn btn-sm btn-outline-secondary" type="button" data-action="export-png">
            {{#str}}export_png, local_chemillusion{{/str}}
        </button>
        {{/pngexportenabled}}
        <button class="btn btn-sm btn-outline-secondary" type="button" data-action="copy-snippet">
            {{#str}}export_copy_snippet, local_chemillusion{{/str}}
        </button>
    </div>
    {{/canexport}}
    {{/exportenabled}}

</div>
